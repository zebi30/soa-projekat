{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Service Logs",
  "uid": "service-logs",
  "tags": ["logs"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "label": "container", "stream": "", "type": 1, "refId": "LokiVariable" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "search",
        "label": "Contains text",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "id": 1,
      "title": "Log volume (lines/interval)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }, "min": 0 },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} |~ \"(?i)$search\" [$__interval]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Errors (last 1h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container=~\"$container\"} |~ \"(?i)error|exception|traceback|fatal|panic\" [$__range]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "type": "logs",
      "id": 3,
      "title": "Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"$container\"} |~ \"(?i)$search\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
